# ── Slack ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Socket Mode (local dev without HTTPS — optional)
# Get from your Slack app → Socket Mode → App-Level Token
# SLACK_APP_TOKEN=xapp-...
# Leave empty to use HTTP mode (production default)
SLACK_APP_TOKEN=

# ── User Container (Mnemo) ────────────────────────────
CONTAINER_URL=http://mnemo-user:8000
# Use container name for Docker network resolution.
# For external URL use: https://your-container-domain.com

USER_API_KEY=
# Must match USER_API_KEY in the user container .env

# ── LLM (your own Ollama instance) ───────────────────
OLLAMA_URL=http://mnemo-ollama:11434
# Point to any Ollama server. Can be shared with other services
# on the same Docker network or a completely separate server.

OLLAMA_MODEL=qwen2.5:3b
# Must be pulled on the Ollama instance: ollama pull qwen2.5:3b

LLM_TIMEOUT=120.0
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

SYSTEM_PROMPT=
# Optional. Override the default system prompt.
# Leave empty to use the built-in prompt.

# ── Bot Behaviour ─────────────────────────────────────
BOT_NAME=Mnemo
QUERY_TIMEOUT=120.0
SHOW_SOURCES=true
SHOW_PROVENANCE=false
TYPING_EMOJI=hourglass_flowing_sand
ERROR_MESSAGE=Sorry, I couldn't process your request. Please try again.

# ── App ───────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=3000
LOG_LEVEL=INFO
